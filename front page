<script>
  // State destination tabs
  function showState(state, btn) {
    document.querySelectorAll('.state-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.state-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('panel-' + state).classList.add('active');
    btn.classList.add('active');
    // Re-trigger scroll animations for new panel
    document.querySelectorAll('#panel-' + state + ' .place-card').forEach((el, i) => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      setTimeout(() => {
        el.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, i * 80);
    });
  }

  // Smooth reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.dest-card, .pkg-card, .testi-card, .why-feature').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(24px)';
    el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    observer.observe(el);
  });

  // Form submit
  document.querySelector('.btn-submit').addEventListener('click', function() {
    this.textContent = '✓ Enquiry Sent! We will contact you soon.';
    this.style.background = 'var(--sage)';
    setTimeout(() => {
      this.textContent = 'Send My Enquiry →';
      this.style.background = 'var(--gold)';
    }, 4000);
  });
</script>

